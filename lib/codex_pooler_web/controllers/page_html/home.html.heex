<Layouts.app flash={@flash} current_scope={@current_scope} auth_surface>
  <section class="mx-auto grid min-h-[calc(100svh-10rem)] w-full max-w-3xl items-center px-4 py-10">
    <div class="border border-base-300 bg-base-100 p-6 shadow-2xl shadow-base-content/10 sm:p-8">
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.28em] text-primary">
        CODEX POOLER / SESSION ACTIVE
      </p>
      <h1 class="mt-3 text-3xl font-black tracking-[-0.06em] text-base-content sm:text-5xl">
        Operator session ready
      </h1>
      <p class="mt-4 max-w-xl text-sm leading-6 text-base-content/70">
        Authentication is configured and your browser has a valid operator session.
      </p>
      <.link href={~p"/logout"} method="delete" class="btn btn-primary mt-6 w-fit">
        Log out
      </.link>
    </div>
  </section>
</Layouts.app>
