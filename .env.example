# Docker Compose self-host settings.
# Copy with `scripts/self-host/generate-env.sh` so secrets are generated safely.
# For a trusted-network plain-HTTP deployment, set PHX_SCHEME=http,
# PHX_PORT to the public port, and DISABLE_FORCE_SSL=true.

CODEX_POOLER_IMAGE=ghcr.io/icoretech/codex-pooler
CODEX_POOLER_IMAGE_TAG=latest
CODEX_POOLER_HTTP_PORT=4000

PHX_HOST=localhost
# PHX_SCHEME=http
# PHX_PORT=4000
# DISABLE_FORCE_SSL=true
CODEX_POOLER_OPERATOR_LOGIN_BASE_URL=http://localhost:4000
OBAN_MODE=all

POSTGRES_DB=codex_pooler_prod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-generated-postgres-password
DATABASE_URL=ecto://postgres:replace-with-generated-postgres-password@db:5432/codex_pooler_prod

SECRET_KEY_BASE=replace-with-generated-secret-key-base
CODEX_POOLER_TOTP_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
CODEX_POOLER_TOTP_KEY_VERSION=v1
CODEX_POOLER_UPSTREAM_SECRET_KEY=replace-with-base64-encoded-32-byte-key
CODEX_POOLER_UPSTREAM_SECRET_KEY_VERSION=v1
